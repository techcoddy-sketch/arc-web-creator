<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="20dp"
    android:layout_gravity="bottom">

    <TextView
        android:id="@+id/snooze_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Snooze reminder"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:paddingBottom="12dp"/>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">
        <LinearLayout
            android:id="@+id/snooze_chips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"/>
    </HorizontalScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="8dp">
        <Button
            android:id="@+id/snooze_tonight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tonight"
            android:textAllCaps="false"
            android:layout_marginEnd="12dp"/>
        <Button
            android:id="@+id/snooze_morning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tomorrow AM"
            android:textAllCaps="false"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Custom"
        android:textColor="#000000"
        android:textStyle="bold"
        android:paddingTop="16dp"
        android:paddingBottom="6dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <EditText
            android:id="@+id/snooze_custom_value"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:hint="e.g. 27"
            android:inputType="number"
            android:textColor="#000000"/>
        <Spinner
            android:id="@+id/snooze_custom_unit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/snooze_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pick a duration"
        android:textColor="#FF6B00"
        android:textStyle="bold"
        android:padding="12dp"
        android:layout_marginTop="12dp"
        android:background="#FFF4ED"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="14dp">
        <Button
            android:id="@+id/snooze_cancel"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textAllCaps="false"
            android:layout_marginEnd="8dp"/>
        <Button
            android:id="@+id/snooze_confirm"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Snooze"
            android:textAllCaps="false"
            android:backgroundTint="#FF6B00"
            android:textColor="#FFFFFF"/>
    </LinearLayout>
</LinearLayout>
